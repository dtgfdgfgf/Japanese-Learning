# ===========================================
# LINE Bot 日語學習助教 環境變數設定範例
# ===========================================
# 複製此檔案為 .env 並填入實際值
# cp .env.example .env

# -------------------------------------------
# LINE Messaging API
# -------------------------------------------
# 從 LINE Developers Console 取得
# https://developers.line.biz/console/
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# -------------------------------------------
# Database (Supabase PostgreSQL)
# -------------------------------------------
# 格式: postgresql+asyncpg://user:password@host:port/database
# Supabase: Settings > Database > Connection string > URI
DATABASE_URL=postgresql+asyncpg://postgres:your_password@db.your_project.supabase.co:5432/postgres

# -------------------------------------------
# LLM API Keys
# -------------------------------------------
# Primary: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here

# Fallback: OpenAI
OPENAI_API_KEY=sk-your_openai_api_key_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# -------------------------------------------
# Application Settings
# -------------------------------------------
APP_ENV=development
LOG_LEVEL=DEBUG

# User ID hashing salt (generate a random string)
USER_ID_SALT=your_random_salt_here_minimum_32_chars

# -------------------------------------------
# Optional: Rate Limiting
# -------------------------------------------
LLM_RATE_LIMIT_PER_MINUTE=10

# -------------------------------------------
# Testing (Optional)
# -------------------------------------------
# 測試用資料庫 URL（應包含 "test" 字樣）
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/japanese_learning_test

# 設為 false 以啟用資料庫整合測試
# SKIP_DB_TESTS=true
