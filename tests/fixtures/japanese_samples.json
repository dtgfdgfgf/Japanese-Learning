  ],
  "grammar_samples": [
    {
      "raw_text": "財布を忘れてしまった。（不小心忘了帶錢包）",
      "expected_items": [
        {
          "item_type": "grammar",
          "key": "grammar:〜てしまう",
          "payload": {
            "pattern": "〜てしまう",
            "meaning_zh": "表示遺憾/不小心做了某事",
            "form_notes": "Vて + しまう"
          }
        }
      ]
    },
    {
      "raw_text": "日本に行ったことがある。（我去過日本）",
      "expected_items": [
        {
          "item_type": "grammar",
          "key": "grammar:〜たことがある",
          "payload": {
            "pattern": "〜たことがある",
            "meaning_zh": "曾經做過某事",
            "form_notes": "Vた + ことがある"
          }
        }
      ]
    }
  ],
  "mixed_samples": [
    {
      "raw_text": "もう少し考えてみます。（我再想想看）這裡的「考える」是動詞，「〜てみる」是表示嘗試的文法。",
      "expected_items": [
        {
          "item_type": "vocab",
          "key": "vocab:考える"
        },
        {
          "item_type": "grammar",
          "key": "grammar:〜てみる"
        }
      ]
    },
    {
      "raw_text": "彼は毎日運動しているらしい。聽說他每天都在運動。",
      "expected_items": [
        {
          "item_type": "vocab",
          "key": "vocab:運動"
        },
        {
          "item_type": "grammar",
          "key": "grammar:〜らしい"
        }
      ]
    }
  ],
  "edge_cases": [
    {
      "description": "Pure Chinese text",
      "raw_text": "今天天氣很好",
      "expected_lang": "unknown",
      "expected_items": []
    },
    {
      "description": "English text",
      "raw_text": "Hello, how are you?",
      "expected_lang": "unknown",
      "expected_items": []
    },
    {
      "description": "Very short text",
